# ── Server ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
# Public URL the server is reachable at (used for redirect display & MCP URL).
PUBLIC_BASE_URL=http://localhost:3000

# ── Datastores ─────────────────────────────────────────────────────────
# For docker compose, host is the service name "postgres"/"redis".
DATABASE_URL=postgresql://gitlab_mcp:gitlab_mcp@localhost:5432/gitlab_mcp?schema=public
REDIS_URL=redis://localhost:6379

# Postgres credentials consumed by docker-compose.yml. POSTGRES_PASSWORD is
# REQUIRED (compose has no default) — pick a strong value. In NODE_ENV=production
# the app refuses to start with a well-known weak password or a localhost DB.
POSTGRES_USER=gitlab_mcp
POSTGRES_PASSWORD=change_me_to_a_strong_password
POSTGRES_DB=gitlab_mcp

# ── GitLab OAuth application ───────────────────────────────────────────
# Default is gitlab.com; set to your self-hosted instance if needed.
GITLAB_BASE_URL=https://gitlab.com
GITLAB_CLIENT_ID=your_oauth_application_id
GITLAB_CLIENT_SECRET=your_oauth_application_secret
# Must EXACTLY match the redirect URI registered on the GitLab OAuth app.
GITLAB_REDIRECT_URI=http://localhost:3000/auth/callback
# Scopes: read_user (login) + api (act on MRs/pipelines as the user).
GITLAB_SCOPES=read_user api

# ── Crypto ─────────────────────────────────────────────────────────────
# 32-byte key for AES-256-GCM token encryption.
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=replace_me_with_64_hex_chars_from_openssl_rand_hex_32

# ── Sessions / tokens ──────────────────────────────────────────────────
SESSION_TTL_HOURS=168
TOKEN_REFRESH_SKEW_SECONDS=60

# OAuth (MCP client-driven). Code TTL is short; refresh TTL longer.
OAUTH_CODE_TTL_SECONDS=60
OAUTH_REFRESH_TTL_HOURS=720
